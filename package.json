{
  "name": "geo-clock-card",
  "version": "0.0.1",
  "description": "Home Assistant Lovelace card with a live world day/night terminator using NASA Blue/Black Marble imagery.",
  "type": "module",
  "main": "dist/geo-clock-card.js",
  "files": [
    "dist/",
    "DESIGN.md",
    "README.md",
    "LICENSE",
    "hacs.json"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch-imagery": "bash scripts/fetch-imagery.sh",
    "fetch-tz": "bash scripts/fetch-tz.sh",
    "fetch-assets": "npm run fetch-imagery && npm run fetch-tz"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "geochron",
    "terminator",
    "world-clock"
  ],
  "license": "MIT",
  "dependencies": {
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "mapshaper": "^0.7.9",
    "rollup": "^4.30.1",
    "rollup-plugin-copy": "^3.5.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
