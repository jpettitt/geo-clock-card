node_modules/
*.log
.DS_Store

# We track dist/ so HACS can install directly from a tagged release.
# Source maps don't need to ship; the JPEGs/JSON are the same files
# already committed under assets/, but HACS needs them sitting next
# to geo-clock-card.js for the SVG <image href> resolution.
dist/*.map

# NASA source imagery cache (~230 MB of PNGs) — regenerate via
# `npm run fetch-imagery`.
.fetch-tmp/

# Resized imagery (assets/blue-marble-*-2048.jpg, black-marble-*) IS
# tracked so a fresh clone has a runnable build without re-fetching.

# Local-test symlink for the geoclock.world demo — see
# docs/web/README.md ("Local testing"). Pointed at ../../dist so the
# page's `/v0.2.x/...` imports resolve against the freshly-built
# bundle. Never commit; production R2 holds the real versioned
# assets. The two patterns (with and without trailing slash) cover
# both directory copies and symlinks — git treats them differently.
docs/web/v*/
docs/web/v*
